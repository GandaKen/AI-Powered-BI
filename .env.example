BIFROST_BASE_URL=http://localhost:8080
LLM_MODEL_LIGHT=llama3.2:3b
LLM_MODEL_HEAVY=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text
LLM_TEMPERATURE=0.0
RAG_TOP_K=5
MAX_EVAL_RETRIES=1
TOKEN_BUDGET_SIMPLE=4000
TOKEN_BUDGET_COMPLEX=12000

# Langfuse observability (cloud or self-hosted)
# Cloud: https://us.cloud.langfuse.com — get keys at https://cloud.langfuse.com
# Self-hosted: http://localhost:3000 — requires 16 GB+ RAM, see .env.selfhosted
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Local trace storage (Postgres) — used by the Observability dashboard
# For Docker: postgresql://insightforge:insightforge@postgres:5432/insightforge
# For local dev: postgresql://insightforge:insightforge@localhost:5432/insightforge
DATABASE_URL=postgresql://insightforge:insightforge@localhost:5432/insightforge
