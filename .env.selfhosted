BIFROST_BASE_URL=http://localhost:8080
LLM_MODEL_LIGHT=llama3.2:3b
LLM_MODEL_HEAVY=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text
LLM_TEMPERATURE=0.0
RAG_TOP_K=5
MAX_EVAL_RETRIES=1
TOKEN_BUDGET_SIMPLE=4000
TOKEN_BUDGET_COMPLEX=12000

# Self-hosted Langfuse (requires 16 GB+ RAM)
# Start with: docker compose -f docker-compose.langfuse.yml up -d
LANGFUSE_PUBLIC_KEY=pk-lf-local-insightforge
LANGFUSE_SECRET_KEY=sk-lf-local-insightforge
LANGFUSE_HOST=http://localhost:3000

# Local trace storage
DATABASE_URL=postgresql://insightforge:insightforge@localhost:5432/insightforge
